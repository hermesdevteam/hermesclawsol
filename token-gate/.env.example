# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=
# Telegram Chat ID (the group to gate)
TELEGRAM_CHAT_ID=
# Telegram invite link for the gated group
TELEGRAM_INVITE_LINK=

# Web URL (your Vercel deployment)
NEXT_PUBLIC_WEB_URL=https://your-project.vercel.app

# $HERMES token mint address on Solana (set after bags.fm launch)
NEXT_PUBLIC_HERMES_TOKEN_MINT=
# Minimum balance to pass gate (in smallest unit, 9 decimals)
HERMES_MIN_BALANCE=1000000000

# Solana RPC
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# HMAC secret for nonce signing
NONCE_SECRET=change-me-to-random-string

# Recheck interval (hours)
RECHECK_INTERVAL_HOURS=24
